@model CMS.Data.Entities.CategoryProduct

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <h2>Chi tiết danh mục sản phẩm</h2>

    <table class="table table-bordered">

        <tr>
            <th>ID</th>
            <td>@Model.Id</td>
        </tr>

        <tr>
            <th>Tên danh mục</th>
            <td>@Model.Name</td>
        </tr>

        <tr>
            <th>Mô tả</th>
            <td>@Model.Description</td>
        </tr>

    </table>

    <a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-warning">
        Sửa
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Quay lại
    </a>

</div>