@model CMS.Data.Entities.CategoryProduct

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <h2>Thêm danh mục</h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <input asp-for="Name" class="form-control mb-2" placeholder="Tên" />

        <textarea asp-for="Description" class="form-control mb-2"></textarea>

        <input type="file" name="imageFile" class="form-control mb-3" />

        <button class="btn btn-success">Lưu</button>

    </form>

</div>