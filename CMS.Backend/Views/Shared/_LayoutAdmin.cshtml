<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - TrucCMS Admin</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>

        body {
            background: #f5f6fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
            position: fixed;
            width: 260px;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 10px 18px;
                border-radius: 6px;
                margin: 4px 10px;
            }

                .sidebar a:hover {
                    background-color: #343a40;
                    color: white;
                }

                .sidebar a.active {
                    background-color: #0d6efd;
                    color: white;
                }

        .content {
            margin-left: 260px;
            padding: 20px;
        }

        .sidebar-header {
            text-align: center;
            padding: 20px;
            border-bottom: 1px solid #495057;
        }

    </style>

</head>

<body>

    <div class="sidebar">

        <!-- HEADER -->
        <div class="sidebar-header">

            <h4 class="text-white mb-1">TrucCMS Admin</h4>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="text-light small">
                    Xin chào:
                    <strong>@User.Identity.Name</strong>
                </div>

                <a class="btn btn-sm btn-danger mt-2"
                   asp-controller="Account"
                   asp-action="Logout">
                    Đăng xuất
                </a>
            }

        </div>

        <!-- MENU -->
        <div class="mt-3">

            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a asp-controller="Category" asp-action="Index">
                <i class="bi bi-grid"></i> Danh mục
            </a>

            <a asp-controller="Post" asp-action="Index">
                <i class="bi bi-file-earmark-post"></i> Bài viết
            </a>

            <a asp-controller="User" asp-action="Index">
                <i class="bi bi-people"></i> Thành viên
            </a>

            <a asp-controller="CategoryProduct" asp-action="Index">
                <i class="bi bi-tags"></i> Danh mục sản phẩm
            </a>

            <a asp-controller="Product" asp-action="Index">
                <i class="bi bi-box"></i> Sản phẩm
            </a>

            <a asp-controller="Customer" asp-action="Index">
                <i class="bi bi-person"></i> Khách hàng
            </a>

            <a asp-controller="Order" asp-action="Index">
                <i class="bi bi-receipt"></i> Đơn hàng
            </a>

            <a asp-controller="OrderDetail" asp-action="Index">
                <i class="bi bi-card-list"></i> Chi tiết đơn hàng
            </a>

        </div>

    </div>

    <!-- CONTENT -->
    <main class="content">

        @RenderBody()

    </main>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>