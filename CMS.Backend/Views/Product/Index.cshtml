@model IEnumerable<CMS.Data.Entities.Product>

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <h2 class="fw-bold text-primary">
            🛒 DANH SÁCH SẢN PHẨM
        </h2>

        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i>
            Thêm sản phẩm
        </a>

    </div>

    <!-- CARD TABLE -->
    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th width="60">ID</th>
                        <th>Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th>Danh mục</th>
                        <th class="text-center" width="180">Thao tác</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-bold">@item.Id</td>

                                <!-- IMAGE -->
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl"
                                             class="rounded border shadow-sm"
                                             style="width:70px; height:70px; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            Không có ảnh
                                        </span>
                                    }
                                </td>

                                <!-- NAME -->
                                <td>
                                    <span class="fw-semibold">
                                        @item.Name
                                    </span>
                                </td>

                                <!-- PRICE -->
                                <td>
                                    <span class="text-danger fw-bold">
                                        @item.Price.ToString("N0") ₫
                                    </span>
                                </td>

                                <!-- STOCK -->
                                <td>
                                    @if (item.StockQuantity > 5)
                                    {
                                        <span class="badge bg-success">
                                            @item.StockQuantity
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            @item.StockQuantity
                                        </span>
                                    }
                                </td>

                                <!-- CATEGORY -->
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @item.CategoryProduct?.Name
                                    </span>
                                </td>

                                <!-- ACTION -->
                                <td class="text-center">

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning me-1">
                                        ✏
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">
                                        🗑
                                    </a>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Không có sản phẩm nào
                            </td>
                        </tr>
                    }
                    <div class="mt-3 text-center">

                        @if (ViewBag.Page > 1)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(ViewBag.Page - 1)"
                               class="btn btn-secondary">
                                Previous
                            </a>
                        }

                        <span class="mx-3">
                            Trang @ViewBag.Page / @ViewBag.TotalPages
                        </span>

                        @if (ViewBag.Page < ViewBag.TotalPages)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(ViewBag.Page + 1)"
                               class="btn btn-primary">
                                Next
                            </a>
                        }

                    </div>
                </tbody>


            </table>

        </div>

    </div>

</div>