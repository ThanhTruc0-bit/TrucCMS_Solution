@model IEnumerable<CMS.Data.Entities.Customer>

<div class="container mt-4">

    <h2 class="text-success mb-4">
        DANH SÁCH KHÁCH HÀNG
    </h2>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Họ Tên</th>
                <th>Email</th>
                <th>Số Điện Thoại</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                </tr>
            }

        </tbody>

    </table>

</div>