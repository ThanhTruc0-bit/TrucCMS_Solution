@model IEnumerable<CMS.Data.Entities.Post>

<div class="container py-5">

    <!-- TITLE -->
    <div class="text-center mb-5">

        <h2 class="fw-bold text-dark">
            ✨ Bộ Sưu Tập Tin Tức Trang Sức
        </h2>

        <p class="text-muted">
            Cập nhật xu hướng trang sức mới nhất, thiết kế cao cấp và phong cách sang trọng
        </p>

    </div>

    <!-- POSTS -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4">

                <div class="card border-0 shadow-sm h-100 post-card">

                    <!-- IMAGE -->
                    <div class="overflow-hidden" style="height: 240px;">

                        <img src="@item.ImageUrl"
                             class="w-100 h-100"
                             style="object-fit: cover; transition: 0.4s;"
                             alt="Post image">

                    </div>

                    <div class="card-body">

                        <!-- CATEGORY -->
                        <span class="badge bg-dark mb-2 px-3 py-2">
                            @item.Category.Name
                        </span>

                        <!-- TITLE -->
                        <h5 class="fw-bold text-dark">
                            @item.Title
                        </h5>

                        <!-- CONTENT -->
                        <p class="text-muted small"
                           style="display:-webkit-box;
                                      -webkit-line-clamp:2;
                                      -webkit-box-orient:vertical;
                                      overflow:hidden;">
                            @item.Content
                        </p>

                        <!-- BUTTON -->
                        <a href="/Post/Details/@item.Id"
                           class="btn btn-outline-dark btn-sm px-3">
                            Xem chi tiết
                        </a>

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer bg-white border-0 text-muted small">

                        📅 @item.CreatedDate.ToString("dd/MM/yyyy")

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<!-- STYLE -->
<style>
    .post-card {
        transition: all 0.3s ease;
        border-radius: 12px;
        overflow: hidden;
    }

        .post-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

        .post-card img:hover {
            transform: scale(1.05);
        }
</style>