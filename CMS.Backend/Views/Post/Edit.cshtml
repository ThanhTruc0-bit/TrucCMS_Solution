@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning text-dark">

            <h4 class="mb-0">
                <i class="bi bi-pencil-square"></i>
                CHỈNH SỬA BÀI VIẾT
            </h4>

        </div>

        <div class="card-body">

            <form asp-action="Edit"
                  method="post"
                  enctype="multipart/form-data">

                <!-- Id ẩn -->
                <input asp-for="Id" type="hidden" />

                <div class="row">

                    <!-- Nội dung bên trái -->
                    <div class="col-md-8">

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Tiêu đề bài viết:
                            </label>

                            <input asp-for="Title"
                                   class="form-control"
                                   placeholder="Nhập tiêu đề..." />

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Nội dung chi tiết:
                            </label>

                            <textarea asp-for="Content"
                                      class="form-control"
                                      rows="10"
                                      placeholder="Viết nội dung tại đây..."></textarea>

                        </div>

                    </div>

                    <!-- Nội dung bên phải -->
                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Chuyên mục:
                            </label>

                            <select asp-for="CategoryId"
                                    class="form-select"
                                    asp-items="ViewBag.CategoryList">

                                <option value="">
                                    -- Chọn danh mục --
                                </option>

                            </select>

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Ảnh hiện tại:
                            </label>

                            <br />

                            <img src="@Model.ImageUrl"
                                 width="250"
                                 class="img-thumbnail" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Chọn ảnh mới:
                            </label>

                            <input type="file"
                                   name="uploadImage"
                                   class="form-control" />

                        </div>
                        <input asp-for="ImageUrl" type="hidden" />

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Ngày đăng:
                            </label>

                            <input asp-for="CreatedDate"
                                   type="date"
                                   class="form-control" />

                        </div>

                        <hr />

                        <div class="d-grid gap-2">

                            <button type="submit"
                                    class="btn btn-warning">

                                <i class="bi bi-save"></i>
                                Cập nhật bài viết

                            </button>

                            <a asp-action="Index"
                               class="btn btn-secondary">

                                <i class="bi bi-arrow-left"></i>
                                Quay lại danh sách

                            </a>

                        </div>

                    </div>

                </div>

            </form>

        </div>

    </div>

</div>