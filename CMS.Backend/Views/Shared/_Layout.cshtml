<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Luxury Jewelry</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

        body {
            background-color: #fafafa;
            font-family: 'Segoe UI', sans-serif;
        }

        /* NAVBAR */
        .navbar {
            background: #fff;
            border-bottom: 1px solid #eee;
            padding: 14px 0;
        }

        .container-flex {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
        }

        /* BRAND */
        .brand {
            font-weight: 700;
            font-size: 20px;
            color: #111;
            text-decoration: none;
            white-space: nowrap;
        }

        /* MENU CENTER */
        .menu {
            display: flex;
            gap: 35px;
            justify-content: center;
            flex: 1;
        }

            .menu a {
                text-decoration: none;
                color: #444;
                font-weight: 500;
                transition: 0.3s;
            }

                .menu a:hover {
                    color: #b08d57;
                }

        /* ADMIN BUTTON */
        .admin-btn {
            background: #111;
            color: #fff;
            padding: 8px 18px;
            border-radius: 25px;
            text-decoration: none;
            white-space: nowrap;
            transition: 0.3s;
        }

            .admin-btn:hover {
                background: #b08d57;
                color: #fff;
            }

        footer {
            margin-top: 60px;
            padding: 20px;
            text-align: center;
            border-top: 1px solid #eee;
            color: #777;
            background: #fff;
        }

    </style>

</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar">

        <div class="container container-flex">

            <!-- LEFT: BRAND -->
            <a class="brand" asp-controller="Home" asp-action="Index">
                💎 Luxury Jewelry
            </a>

            <!-- CENTER: MENU -->
            <div class="menu">

                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Product" asp-action="Index">Sản phẩm</a>
                <a asp-controller="Post" asp-action="Index">Tin tức</a>
                <a asp-controller="Home" asp-action="Privacy">Chính sách</a>

            </div>

            <!-- RIGHT: ADMIN -->
            <a class="admin-btn"
               asp-controller="Dashboard"
               asp-action="Index">

                <i class="bi bi-gear-fill"></i>
                Admin

            </a>

        </div>

    </nav>

    <!-- CONTENT -->
    <div class="container py-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer>
        <strong>Luxury Jewelry</strong> © 2026
    </footer>

</body>

</html>